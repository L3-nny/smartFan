@page "/dashboard"
@using smartFan.BlazorUI.Models
@using smartFan.BlazorUI.Services
@using smartFan.BlazorUI.Components
@inject IDeviceService DeviceService
@inject IActuatorService ActuatorService
@inject ILogger<Dashboard> Logger
@implements IDisposable

<PageTitle>Smart Fan Dashboard</PageTitle>

<div class="min-h-screen bg-gray-100 p-4">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Smart Fan Control Dashboard</h1>
            <p class="text-gray-600">Monitor and control your smart fan system in real-time</p>
        </div>

        <!-- Loading State -->
        @if (IsInitialLoading)
        {
            <div class="flex items-center justify-center py-32">
                <div class="text-center">
                    <div class="animate-spin rounded-full h-16 w-16 border-b-2 border-blue-500 mx-auto mb-4"></div>
                    <p class="text-gray-600">Loading dashboard...</p>
                </div>
            </div>
        }
        else
        {
            <!-- Dashboard Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Left Column -->
                <div class="space-y-6">
                    <!-- Device Status Card -->
                    <DeviceStatusCard DeviceStatus="@CurrentDeviceStatus" 
                                    DeviceId="1" 
                                    IsLoading="@IsRefreshing" />

                    <!-- Manual Override Panel -->
                    <ManualOverridePanel CurrentFanSpeed="@CurrentDeviceStatus?.CurrentFanSpeed"
                                       IsLoading="@IsAdjusting"
                                       OnFanSpeedSelected="@HandleManualOverride"
                                       StatusMessage="@StatusMessage"
                                       IsError="@IsError" />
                </div>

                <!-- Right Column -->
                <div>
                    <!-- Fan Control Gauge -->
                    <FanControlGauge DeviceStatus="@CurrentDeviceStatus"
                                   IsLoading="@IsAdjusting"
                                   OnSpeedChange="@HandleManualOverride" />
                </div>
            </div>

            <!-- Footer Info -->
            <div class="mt-8 bg-white rounded-lg shadow-sm p-4">
                <div class="flex flex-wrap items-center justify-between text-sm text-gray-600">
                    <div class="flex items-center space-x-4">
                        <span>Auto-refresh: 
                            <span class="font-medium text-green-600">
                                @if (IsAutoRefreshEnabled) { <text>Enabled</text> } else { <text>Disabled</text> }
                            </span>
                        </span>
                        <button @onclick="ToggleAutoRefresh" 
                                class="px-3 py-1 rounded bg-blue-100 text-blue-700 hover:bg-blue-200 transition-colors">
                            @if (IsAutoRefreshEnabled) { <text>Disable</text> } else { <text>Enable</text> }
                        </button>
                    </div>
                    <div>
                        Last updated: @(CurrentDeviceStatus?.LastUpdated.ToString("HH:mm:ss") ?? "Never")
                    </div>
                </div>
            </div>
        }

        <!-- Error Toast -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="fixed top-4 right-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded shadow-lg max-w-md">
                <div class="flex items-center justify-between">
                    <div>
                        <strong class="font-bold">Error!</strong>
                        <span class="block sm:inline">@ErrorMessage</span>
                    </div>
                    <button @onclick="ClearError" class="ml-4 text-red-700 hover:text-red-900">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                        </svg>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private DeviceStatus? CurrentDeviceStatus { get; set; }
    private Timer? RefreshTimer { get; set; }
    private Timer? ErrorClearTimer { get; set; }
    
    private bool IsInitialLoading { get; set; } = true;
    private bool IsRefreshing { get; set; } = false;
    private bool IsAdjusting { get; set; } = false;
    private bool IsAutoRefreshEnabled { get; set; } = true;
    private bool IsError { get; set; } = false;
    
    private string? StatusMessage { get; set; }
    private string? ErrorMessage { get; set; }
    
    private const int RefreshIntervalMs = 5000; // 5 seconds
    private const int ErrorDisplayMs = 5000; // 5 seconds

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("Dashboard initialized");
        await LoadDeviceStatus();
        StartAutoRefresh();
        IsInitialLoading = false;
    }

    private async Task LoadDeviceStatus()
    {
        try
        {
            IsRefreshing = true;
            StateHasChanged();

            var deviceStatus = await DeviceService.GetDeviceStatusAsync();
            
            if (deviceStatus != null)
            {
                CurrentDeviceStatus = deviceStatus;
                ClearError();
                Logger.LogInformation("Device status loaded: {Temperature}°C, {FanSpeed}", 
                    deviceStatus.Temperature, deviceStatus.CurrentFanSpeed);
            }
            else
            {
                ShowError("Failed to load device status");
                Logger.LogWarning("Failed to load device status - service returned null");
            }
        }
        catch (Exception ex)
        {
            ShowError($"Error loading device status: {ex.Message}");
            Logger.LogError(ex, "Exception occurred while loading device status");
        }
        finally
        {
            IsRefreshing = false;
            StateHasChanged();
        }
    }

    private async Task HandleManualOverride(FanSpeed fanSpeed)
    {
        try
        {
            IsAdjusting = true;
            IsError = false;
            StatusMessage = $"Setting fan speed to {fanSpeed}...";
            StateHasChanged();

            Logger.LogInformation("Manual override requested: {FanSpeed}", fanSpeed);

            var result = await ActuatorService.SetManualFanSpeedAsync(fanSpeed);
            
            if (result != null)
            {
                StatusMessage = $"Fan speed set to {result.NewFanSpeed}";
                IsError = false;
                
                // Update the current device status immediately for better UX
                if (CurrentDeviceStatus != null)
                {
                    CurrentDeviceStatus.CurrentFanSpeed = fanSpeed;
                    CurrentDeviceStatus.Mode = FanMode.Manual;
                    CurrentDeviceStatus.Rpm = CalculateRpm(fanSpeed);
                    CurrentDeviceStatus.LastUpdated = DateTime.Now;
                }

                // Clear status message after 3 seconds
                _ = Task.Run(async () =>
                {
                    await Task.Delay(3000);
                    StatusMessage = null;
                    await InvokeAsync(StateHasChanged);
                });

                // Refresh device status after a short delay to get updated values
                _ = Task.Run(async () =>
                {
                    await Task.Delay(2000);
                    await LoadDeviceStatus();
                });

                Logger.LogInformation("Manual override successful: {FanSpeed}", result.NewFanSpeed);
            }
            else
            {
                StatusMessage = "Failed to adjust fan speed";
                IsError = true;
                Logger.LogWarning("Manual override failed - service returned null");
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
            IsError = true;
            Logger.LogError(ex, "Exception occurred during manual override");
        }
        finally
        {
            IsAdjusting = false;
            StateHasChanged();
        }
    }

    private void StartAutoRefresh()
    {
        if (IsAutoRefreshEnabled && RefreshTimer == null)
        {
            RefreshTimer = new Timer(async _ => 
            {
                if (!IsAdjusting) // Don't refresh while adjusting
                {
                    await InvokeAsync(LoadDeviceStatus);
                }
            }, null, RefreshIntervalMs, RefreshIntervalMs);
        }
    }

    private void StopAutoRefresh()
    {
        RefreshTimer?.Dispose();
        RefreshTimer = null;
    }

    private void ToggleAutoRefresh()
    {
        IsAutoRefreshEnabled = !IsAutoRefreshEnabled;
        
        if (IsAutoRefreshEnabled)
        {
            StartAutoRefresh();
        }
        else
        {
            StopAutoRefresh();
        }
        
        Logger.LogInformation("Auto-refresh {Status}", IsAutoRefreshEnabled ? "enabled" : "disabled");
    }

    private void ShowError(string message)
    {
        ErrorMessage = message;
        
        // Auto-clear error after 5 seconds
        ErrorClearTimer?.Dispose();
        ErrorClearTimer = new Timer(_ => 
        {
            ErrorMessage = null;
            InvokeAsync(StateHasChanged);
        }, null, ErrorDisplayMs, Timeout.Infinite);
    }

    private void ClearError()
    {
        ErrorMessage = null;
        ErrorClearTimer?.Dispose();
        ErrorClearTimer = null;
    }

    private int CalculateRpm(FanSpeed fanSpeed)
    {
        return fanSpeed switch
        {
            FanSpeed.Off => 0,
            FanSpeed.Low => 300,
            FanSpeed.Medium => 600,
            FanSpeed.High => 900,
            _ => 0
        };
    }

    public void Dispose()
    {
        RefreshTimer?.Dispose();
        ErrorClearTimer?.Dispose();
        Logger.LogInformation("Dashboard disposed");
    }
}